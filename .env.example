NODE_ENV=development
PORT=5178

# Server Base URL (for OAuth callback)
SERVER_BASE_URL=http://your-server-ip:5178

# Database
DATABASE_PATH=./database/openclaw_relay.db

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=30d

# Feishu
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxx

# GLM API Configuration (for OpenClaw sandbox configuration)
# Use separate API keys for different model tiers
ZHIPU_API_KEY_GLM4=your-glm4-api-key
ZHIPU_API_KEY_GLM5=your-glm5-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Docker Configuration
DOCKER_NETWORK=synapse-net
DOCKER_IMAGE=openclaw/gateway:latest
DOCKER_STORAGE_PATH=/root/.openclaw/storage/{userId}

# Orchestrator Configuration
SANDBOX_AUTO_REMOVE=true
SANDBOX_CLEANUP_INTERVAL=3600000

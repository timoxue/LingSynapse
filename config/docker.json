{
  "network": "synapse-net",
  "image": "openclaw/gateway:local",
  "containerPrefix": "openclaw-sandbox-",
  "gatewayPort": 18789,
  "internalGatewayPort": 18789,
  "storagePath": "/Users/timo/openclaw/sandboxes/{userId}/storage",
  "autoRemove": true,
  "environment": {
    "NODE_ENV": "production",
    "OPENCLAW_CONFIG_DIR": "/app/.openclaw"
  }
}
